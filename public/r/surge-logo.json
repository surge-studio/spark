      "content": "import { cn } from '@/lib/utils';\nimport type { FC } from 'react';\n\ninterface SurgeLogoProps {\n  readonly variant?: 'default' | 'symbol' | 'wordmark';\n  readonly orientation?: 'horizontal' | 'vertical';\n  readonly className?: string;\n}\n\nconst Wordmark: FC<Pick<SurgeLogoProps, 'className'>> = ({ className }) => (\n  <svg\n    className={cn('w-32', className)}\n    fill=\"currentColor\"\n    version=\"1.1\"\n    viewBox=\"0 0 180.4 21.7\"\n    xmlns=\"http://www.w3.org/2000/svg\"\n    xmlnsXlink=\"http://www.w3.org/1999/xlink\"\n    xmlSpace=\"preserve\"\n    x=\"0px\"\n    y=\"0px\"\n  >\n    <g id=\"Text\">\n      <g>\n        <path d=\"M0,4.2C0,1.4,1.6,0,4.7,0s4.7,1.4,4.7,4.2v2.6H6.6V4.2C6.6,3,6,2.4,4.7,2.4l0,0C3.4,2.4,2.8,3,2.8,4.2v2C2.8,7.3,4,8.6,6.3,10c2.1,1.3,3.2,2.9,3.2,4.7v2.7c0,2.8-1.6,4.2-4.7,4.2c-3.2,0-4.7-1.4-4.7-4.2v-2.6h2.8v2.6c0,1.2,0.6,1.8,1.9,1.8s1.9-0.6,1.9-1.8v-2.5c0-1.2-1.2-2.5-3.5-3.9C1.1,9.7,0,8.1,0,6.2C0,6.2,0,4.2,0,4.2z\" />\n        <path d=\"M52.5,17.5c0,2.8-1.6,4.2-4.7,4.2c-3.1,0-4.7-1.4-4.7-4.2V0.4h2.8v17.1c0,1.2,0.6,1.8,1.9,1.8s1.9-0.6,1.9-1.8V0.4h2.8V17.5z\" />\n        <path d=\"M86.2,0.3H91c2.9,0,4.3,1.4,4.3,4.2v3.3c0,1.8-1,2.9-2.9,3.6l3.9,9.9h-3.1L90,11.8l-1.1,0.1v9.4h-2.8L86.2,0.3L86.2,0.3z M89,2.7v6.9h1.2c0.5,0,0.9,0,1.2-0.1c0.8-0.3,1.2-0.9,1.2-1.7V4.5c0-1.2-0.6-1.8-1.9-1.8L89,2.7L89,2.7z\" />\n        <path d=\"M138.4,17.5c0,2.8-1.6,4.2-4.7,4.2c-3.1,0-4.7-1.4-4.7-4.2V4.3c0-2.8,1.6-4.2,4.7-4.2s4.7,1.4,4.7,4.2v2.6h-2.8V4.3c0-1.2-0.6-1.8-1.9-1.8l0,0c-1.3,0-1.9,0.6-1.9,1.8v13.2c0,1.2,0.6,1.8,1.9,1.8s1.9-0.6,1.9-1.8v-5.4h-1.8V9.7h4.6V17.5z\" />\n        <path d=\"M172,0.3h8.4v2.4h-5.7v6.9h4.9V12h-4.9v6.9h5.7v2.4H172V0.3z\" />\n      </g>\n    </g>\n  </svg>\n);\n\nconst Symbol: FC<Pick<SurgeLogoProps, 'className'>> = ({ className }) => (\n  <svg\n    className={cn('w-8', className)}\n    fill=\"currentColor\"\n    version=\"1.1\"\n    viewBox=\"0 0 93.2 116.6\"\n    xmlns=\"http://www.w3.org/2000/svg\"\n    xmlnsXlink=\"http://www.w3.org/1999/xlink\"\n    xmlSpace=\"preserve\"\n    x=\"0px\"\n    y=\"0px\"\n  >\n    <g>\n      <g>\n        <path d=\"M7.9,96.6c-0.3,0-0.7-0.1-0.9-0.3c-0.5-0.5-0.5-1.3,0-1.8l34.9-34.9H21.3c-0.5,0-1-0.3-1.2-0.8c-0.2-0.5-0.1-1,0.3-1.3l40.2-40.2c0.5-0.5,1.3-0.5,1.8,0s0.5,1.3,0,1.8l-37.9,38h20.5c0.5,0,1,0.3,1.2,0.8c0.2,0.5,0.1,1-0.3,1.3l-37,37C8.5,96.5,8.2,96.6,7.9,96.6z\" />\n      </g>\n      <path d=\"M92.8,2.1c0.5-0.5,0.5-1.3,0-1.8s-1.3-0.5-1.8,0L40.6,50.8c-0.3,0.3-0.5,0.9-0.3,1.3c0.2,0.5,0.7,0.8,1.2,0.8H62L0.4,114.5c-0.5,0.5-0.5,1.3,0,1.8c0.3,0.3,0.6,0.3,0.9,0.3s0.7-0.1,0.9-0.3l63.8-63.8c0.3-0.3,0.5-0.9,0.3-1.3c-0.2-0.5-0.7-0.8-1.2-0.8h-7.1l31.2-31.2c0.5-0.5,0.5-1.3,0-1.8s-1.3-0.5-1.8,0l-33.2,33h-9.8L92.8,2.1z\" />\n      <g>\n        <path d=\"M34.7,96.6c-0.3,0-0.7-0.1-0.9-0.3c-0.5-0.5-0.5-1.3,0-1.8l30.2-30.2c0.5-0.5,1.3-0.5,1.8,0c0.5,0.5,0.5,1.3,0,1.8L35.6,96.2C35.4,96.5,35.1,96.6,34.7,96.6z\" />\n      </g>\n    </g>\n  </svg>\n);\n\nconst FullLogo: FC<Pick<SurgeLogoProps, 'orientation' | 'className'>> = ({\n  orientation = 'horizontal',\n  className,\n}) => (\n  <div\n    className={cn(\n      'inline-flex items-center gap-6',\n      orientation === 'vertical' && 'flex-col',\n      className\n    )}\n  >\n    <Symbol />\n    <Wordmark />\n  </div>\n);\n\nconst SurgeLogo: FC<SurgeLogoProps> = ({ variant, orientation, className }) => {\n  if (variant === 'symbol') {\n    return <Symbol className={className} />;\n  }\n  if (variant === 'wordmark') {\n    return <Wordmark className={className} />;\n  }\n  return <FullLogo orientation={orientation} className={className} />;\n};\n\nexport { SurgeLogo };\nexport type { SurgeLogoProps };\n",
